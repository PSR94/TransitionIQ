# TransitionIQ - local environment variables
# Copy this file to .env and adjust values for your machine.

# PostgreSQL connection string
# Local:   postgresql://postgres:password@localhost:5432/transitioniq
# Neon:    postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/transitioniq?sslmode=require
DATABASE_URL=postgresql://postgres:password@localhost:5432/transitioniq

# Secret used to sign JWT tokens — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=change_me_to_a_long_random_string_at_least_64_chars

# Optional OpenAI adapter for the Coverage Guide chat and richer explanation text.
# Leave unset for deterministic local demo behavior.
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=

# API server port
PORT=3001

# Web dev server port and API proxy target
WEB_PORT=5173
VITE_API_TARGET=http://localhost:3001
